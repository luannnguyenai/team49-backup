{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/log_hook.py",
            "statusMessage": "Logging Codex prompt"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/log_hook.py",
            "statusMessage": "Logging Codex tool activity"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/log_hook.py",
            "statusMessage": "Logging Codex stop event"
          }
        ]
      }
    ]
  }
}