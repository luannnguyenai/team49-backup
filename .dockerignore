# =============================================================================
# .dockerignore — Backend (root context)
# =============================================================================

# Python artefacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
reports/

# Database files
*.db
*.sqlite
*.sqlite3
app.db

# Environment & secrets
.env
.env.local
.env.*.local

# Logs
logs/
*.log
.ai-log/

# Media / large data files
*.mp4
**/*.mp4
data/*.pdf
data/*.zip
*.tar.gz
data/*/*.mp4    
# Git & tooling
.git/
.github/
.gitignore
.vscode/
.idea/
.DS_Store

# Documentation
*.md
architecture_*.png
*.ipynb

# Frontend (not needed in backend image)
frontend/
node_modules/

# Test artefacts
build.log
crawl.ipynb
test_stream.py
WORKLOG*.md
JOURNAL*.md
AGENTS.md
