      "question": "In the simplified linear analysis of backpropagation through time, what repeatedly determines the gradient as we move farther back in the sequence?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "Repeated multiplication by powers of the recurrent matrix",
        "Only the current input embedding at each position",
        "A fresh optimizer state that resets every step",
        "The output softmax temperature"
      ],
      "answer_index": 0,
