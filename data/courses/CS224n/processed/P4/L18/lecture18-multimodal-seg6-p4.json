      "question": "What is Winoground mainly used to test?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "The ability to train object detectors with web-scale data.",
        "The ability to distinguish captions that use the same words but differ in relationships or constituent order, and match them to the correct image.",
