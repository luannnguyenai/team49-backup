      "question": "What is the defining parameter-sharing idea of an RNN?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "Each time step has its own independent weight matrices",
        "The same weights are reused across successive time steps",
        "The output layer is removed during training",
        "The vocabulary is resampled at each step"
      ],
      "answer_index": 1,
      "explanation": "RNNs share one set of recurrent parameters across time so the same update rule is applied at every position in the sequence.",
