      "question": "What does teacher forcing do during training?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "It lets the model freely sample its own outputs at every step",
        "It feeds the correct next token back in as the next input",
        "It removes the output softmax during early epochs",
        "It averages hidden states across the entire batch before prediction"
      ],
      "answer_index": 1,
      "explanation": "Teacher forcing uses the ground-truth token sequence during training so each prediction is conditioned on a real prefix rather than on the model’s sampled mistakes.",
