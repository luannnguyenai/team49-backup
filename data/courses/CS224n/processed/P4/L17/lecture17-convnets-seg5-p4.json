      "type": "multiple_choice",
      "question": "Why is phrase-level sentiment supervision richer than only labeling whole sentences?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "It gives training signals for intermediate phrases, including places where local sentiment changes before the full sentence is complete.",
        "It removes the need to know the sentence-level label.",
        "It guarantees that every individual word has the same sentiment as the full sentence.",
        "It trains only on punctuation marks rather than words or phrases."
      ],
      "answer_index": 0,
      "explanation": "Labeling internal tree nodes teaches the model how sentiment is built and modified across phrases, not just what the final sentence label should be.",
