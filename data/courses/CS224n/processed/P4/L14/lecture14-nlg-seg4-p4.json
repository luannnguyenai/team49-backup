      "item_type": "concept_mcq",
      "knowledge_scope": "transferable",
      "render_mode": "standard_mcq",
      "type": "multiple_choice",
      "question": "Why is top-p, or nucleus, sampling often more adaptive than fixed top-k sampling?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "It chooses the smallest candidate set whose cumulative probability mass passes a threshold.",
        "It always uses exactly the same number of candidate tokens.",
        "It bans the most likely token whenever the distribution is sharp.",
        "It replaces probabilities with uniform scores across the vocabulary."
      ],
      "answer_index": 0,
      "explanation": "Top-p adapts the number of options to the shape of the distribution. A sharp distribution may need few tokens, while a flatter distribution may need more viable candidates.",
      "answer_explanation_format": "plain_text",
      "primary_kp_id": "kp_sampling_based_decoding_controls",
