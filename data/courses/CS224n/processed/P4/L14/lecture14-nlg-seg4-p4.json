      "type": "multiple_choice",
      "question": "Why introduce sampling into open-ended decoding?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "To avoid always following a single highest-probability continuation.",
        "To make the model ignore its next-token distribution.",
        "To force every generated sequence to match a reference exactly.",
        "To remove all randomness from generation."
      ],
      "answer_index": 0,
      "explanation": "Open-ended text often has many valid continuations. Sampling lets the model choose among plausible options instead of always taking the same argmax path.",
      "answer_explanation_format": "plain_text",
      "primary_kp_id": "kp_sampling_based_decoding_controls",
      "difficulty": "easy",
