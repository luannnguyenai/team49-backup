      "render_mode": "standard_mcq",
      "type": "multiple_choice",
      "question": "How does temperature affect a next-token distribution?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "Higher temperature flattens the distribution, while lower temperature sharpens it toward greedy decoding.",
        "Higher temperature removes all low-probability tokens from consideration.",
        "Lower temperature makes every token equally likely.",
        "Temperature changes only the length of the output, not token probabilities."
      ],
      "answer_index": 0,
      "explanation": "Temperature rescales logits before softmax. Increasing it spreads probability mass across more tokens, while decreasing it concentrates mass on the most likely tokens.",
      "answer_explanation_format": "plain_text",
