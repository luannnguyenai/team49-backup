      "render_mode": "standard_mcq",
      "type": "multiple_choice",
      "question": "Why can vanilla sampling from the full vocabulary produce bad tokens?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "Language distributions are heavy-tailed, so many low-probability bad tokens can have substantial total mass.",
        "The top token always has probability zero.",
        "The model cannot assign probabilities to rare tokens.",
        "Vanilla sampling only chooses tokens not in the vocabulary."
      ],
      "answer_index": 0,
      "explanation": "Even if each bad token is unlikely, there may be many of them. Their combined probability can be large enough that unconstrained sampling sometimes picks one.",
      "answer_explanation_format": "plain_text",
      "primary_kp_id": "kp_sampling_based_decoding_controls",
      "difficulty": "medium",
