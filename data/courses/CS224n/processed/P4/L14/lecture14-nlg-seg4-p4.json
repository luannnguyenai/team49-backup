      "render_mode": "standard_mcq",
      "type": "multiple_choice",
      "question": "What is the basic idea of reranking sampled candidates?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "Generate multiple candidates, score them with quality criteria, and choose the best-scoring one.",
        "Generate one token greedily and never revise the sequence.",
        "Replace the language model with a fixed n-gram blocking rule.",
        "Choose the shortest candidate regardless of quality."
      ],
      "answer_index": 0,
      "explanation": "Reranking separates generation from selection. Sampling creates diverse candidates, and additional scoring functions can prefer outputs with better coherence, style, factuality, or consistency.",
      "answer_explanation_format": "plain_text",
      "primary_kp_id": "kp_reranking_sampled_candidates",
