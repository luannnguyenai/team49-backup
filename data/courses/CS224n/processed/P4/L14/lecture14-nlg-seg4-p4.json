      "item_type": "concept_mcq",
      "knowledge_scope": "transferable",
      "render_mode": "standard_mcq",
      "type": "multiple_choice",
      "question": "What does top-k sampling do?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "It samples only from the k highest-probability tokens after zeroing out the rest.",
        "It always picks the kth most likely token.",
        "It samples from all tokens whose cumulative probability exceeds k.",
        "It reranks complete sequences using a separate classifier."
      ],
      "answer_index": 0,
      "explanation": "Top-k truncates the next-token distribution to a fixed-size candidate set. This reduces tail risk but can be too restrictive or too permissive depending on the distribution.",
      "answer_explanation_format": "plain_text",
      "primary_kp_id": "kp_sampling_based_decoding_controls",
      "difficulty": "easy",
