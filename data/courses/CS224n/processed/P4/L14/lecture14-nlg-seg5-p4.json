      "question": "What is exposure bias in autoregressive generation?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "A train-test mismatch where training uses gold prefixes but generation uses the model's own imperfect prefixes.",
        "A decoding rule that removes all low-probability tokens.",
        "A metric failure caused only by lexical overlap.",
        "A bias that appears only when the vocabulary has no rare words."
      ],
      "answer_index": 0,
      "explanation": "During training, the model sees clean human prefixes. During generation, small model mistakes can become part of the context, causing future predictions to drift.",
      "answer_explanation_format": "plain_text",
