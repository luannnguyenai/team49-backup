      "type": "multiple_choice",
      "question": "How does scheduled sampling try to reduce exposure bias?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "It gradually mixes model-generated tokens into the training context instead of always using gold tokens.",
        "It removes the loss on all generated tokens.",
        "It uses only human evaluation as a reward signal.",
        "It restricts decoding to the top p probability mass."
      ],
      "answer_index": 0,
      "explanation": "Scheduled sampling exposes the model to the kind of imperfect contexts it will encounter at generation time, narrowing the gap between training and inference.",
      "answer_explanation_format": "plain_text",
