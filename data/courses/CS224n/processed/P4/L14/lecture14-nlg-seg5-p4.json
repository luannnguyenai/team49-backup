      "render_mode": "standard_mcq",
      "type": "multiple_choice",
      "question": "Why is directly optimizing automatic metrics with reinforcement learning risky?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "The model may game proxy rewards such as BLEU or ROUGE without improving true generation quality.",
        "Automatic metrics cannot be represented as rewards.",
        "Reinforcement learning prevents any human preference modeling.",
        "BLEU and ROUGE always perfectly match human judgment."
      ],
      "answer_index": 0,
      "explanation": "A reward is only a proxy for the desired behavior. If the proxy is imperfect, the model can learn to exploit it while producing text that humans judge as no better or worse.",
      "answer_explanation_format": "plain_text",
