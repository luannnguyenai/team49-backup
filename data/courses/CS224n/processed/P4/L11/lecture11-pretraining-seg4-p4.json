      "type": "multiple_choice",
      "question": "Why is ordinary next-word prediction not a suitable pretraining objective for a bidirectional encoder?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "The encoder can attend to both sides, so the target token can leak through the input context.",
        "The encoder has no token embeddings to update.",
        "The encoder can only process one token at a time from left to right.",
        "Next-word prediction requires labeled sentiment examples."
      ],
      "answer_index": 0,
      "explanation": "A bidirectional encoder sees information from both directions. If asked to predict a token that remains visible in its context, the task can become trivial instead of teaching robust representations.",
      "answer_explanation_format": "plain_text",
