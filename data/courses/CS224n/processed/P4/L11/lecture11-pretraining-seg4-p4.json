      "question": "What does masked language modeling train an encoder to do?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "Reconstruct selected missing tokens using the surrounding bidirectional context.",
        "Generate text strictly left to right without seeing future tokens.",
        "Translate every input sentence into another language.",
        "Predict only whether two documents have the same author."
      ],
      "answer_index": 0,
      "explanation": "Masked language modeling corrupts some input positions and computes loss on those positions. The encoder must use both left and right context to infer the missing words.",
