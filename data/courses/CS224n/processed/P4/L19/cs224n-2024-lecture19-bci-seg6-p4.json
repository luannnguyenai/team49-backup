      "question": "Why is CTC a good fit for the neural-to-phoneme part of this system?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "Because the alignment is monotonic and the input sequence is much longer than the output sequence",
        "Because it requires fully observed frame-level labels",
        "Because it assumes arbitrary reordering like machine translation",
        "Because it can decode only whole words, not phonemes"
      ],
      "answer_index": 0,
