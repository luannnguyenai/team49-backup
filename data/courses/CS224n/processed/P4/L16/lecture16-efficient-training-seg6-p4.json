      "question": "How can FSDP reduce the apparent cost of communication during the forward pass?",
      "stem_format": "plain_text",
      "choices_format": "plain_text",
      "choices": [
        "By prefetching the next unit's parameters while computation is still running on the current unit.",
        "By refusing to communicate parameters until the entire epoch is finished.",
        "By storing every layer permanently on every GPU during training.",
        "By replacing all-gather with random parameter sampling."
      ],
      "answer_index": 0,
      "explanation": "Communication is less costly when it overlaps with useful computation. Prefetching lets parameter transfer happen while the GPU is busy with the current layer.",
      "answer_explanation_format": "plain_text",
