digraph KG {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad="0.35",
    nodesep="0.35",
    ranksep="0.9",
    label="P5 prerequisite KG kept-only view after GPT-5.4 audit suggestions",
    labelloc="t",
    fontsize="22",
    fontname="Helvetica"
  ];
  node [shape=box, style="rounded,filled", fillcolor="#f8fafc", color="#94a3b8", penwidth=1.2, fontname="Helvetica", fontsize=10, margin="0.08,0.05"];
  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7, penwidth=1.4];
  "kp_3d_datasets_and_ai_geometry_task_space" [label="3D datasets and\nAI+geometry task space", fillcolor="#ecfeff", tooltip="The data and problem formulations that enabled 3D learning, including large object datasets, scanned scene data, and generative/discriminative/multimodal tasks."];
  "kp_activation_functions" [label="Activation functions and\nnonlinearities", fillcolor="#fff7ed", tooltip="Differentiable nonlinear activation functions such as sigmoid, tanh, ReLU, and ReLU-like variants are needed so networks can model nonlinear functions and support gradient-based learning. The idea that activations between linear maps prevent the network from collapsing into a single linear transformation and allow nonlinear decision boundaries."];
  "kp_activation_memory_as_a_separate_bottleneck" [label="Activation memory as a\nseparate bottleneck", fillcolor="#ecfeff", tooltip="Model activations must be stored for backpropagation, scale with batch size, and are not automatically reduced by parameter or optimizer sharding."];
  "kp_adam_and_adamw" [label="Adam and AdamW", fillcolor="#fff7ed", tooltip="Adam combines momentum and RMSProp-style adaptivity; AdamW decouples weight decay from moment estimation."];
  "kp_atlasnet_and_deep_implicit_shape_decoders" [label="AtlasNet and deep\nimplicit shape decoders", fillcolor="#fff7ed", tooltip="Learned mappings from low-dimensional parameter spaces or x,y,z queries to geometry, covering both patch-based surface decoders and occupancy/SDF-style networks."];
  "kp_attention_scoring" [label="Attention scoring and\nalignment weights", fillcolor="#fff7ed", tooltip="Attention begins by comparing a decoder/query state with each candidate source state, then applying softmax to turn those scores into normalized attention weights. Attention scores can be computed with dot-product, bilinear/multiplicative, low-rank projected dot-product, or additive neural-net scoring."];
  "kp_autoencoder_bottlenecks_and_latent_codes" [label="Autoencoder bottlenecks\nand latent codes", fillcolor="#ecfeff", tooltip="A bottlenecked autoencoder learns compressed latent codes useful for representation learning, but plain reconstruction alone does not make the latent space sampleable for generation."];
  "kp_automatic_evaluation_metrics_for_nlg" [label="Automatic evaluation\nmetrics for NLG", fillcolor="#ecfeff", tooltip="The landscape of reference-based lexical and embedding-based automatic metrics used to score generated text."];
  "kp_autoregressive_language_modeling" [label="Autoregressive language\nmodeling", fillcolor="#ecfeff", tooltip="Training a model to predict the next token from its prefix, used directly for decoder pretraining and as a baseline pretraining objective more broadly. Autoregressive models make sequence modeling tractable by factoring p(x) into conditional next-part distributions over an ordered decomposition of x."];
  "kp_autoregressive_trajectory_modeling_and_prompting_in_a_loop" [label="Autoregressive\ntrajectory modeling and\nprompting in a loop", fillcolor="#f8fafc", tooltip="Model action selection as next-token prediction over state-action histories and repeatedly query the model for the next action."];
  "kp_axis_based_reductions_and_keepdims" [label="Axis-based reductions\nand keepdims", fillcolor="#fff7ed", tooltip="Using axis arguments to reduce over dimensions and keepdims to preserve dimensionality."];
  "kp_backpropagation_as_recursive_chain_rule" [label="Backpropagation as\nrecursive chain rule", fillcolor="#fff7ed", tooltip="The backward traversal of a computational graph that repeatedly applies the chain rule to obtain gradients for all relevant variables and parameters."];
  "kp_benchmark_contamination" [label="Benchmark contamination\nand overfitting", fillcolor="#fff7ed", tooltip="Benchmark scores can shift because of formatting, implementation differences, train-test leakage, or repeated tuning on public tests. The problem that benchmark examples may leak into pretraining data, undermining claims of true generalization."];
  "kp_bert_and_encoder_transfer" [label="BERT and encoder\ntransfer", fillcolor="#fff7ed", tooltip="Using a pretrained bidirectional encoder such as BERT for downstream tasks by attaching lightweight prediction heads and fine-tuning."];
  "kp_causal_self_attention" [label="Causal masking and\nmasked self-attention", fillcolor="#fff7ed", tooltip="Masking blocks selected attention links by forcing their pre-softmax scores to negative infinity, which is essential for autoregressive language modeling. Future positions are masked in decoder self-attention so next-token prediction cannot cheat by reading words that come later in the sequence."];
  "kp_chain_of_thought_prompting" [label="Chain-of-thought\nprompting", fillcolor="#ecfeff", tooltip="A prompting strategy that asks the model to generate intermediate reasoning before answering, either via exemplars or zero-shot prompting. Prompting with worked intermediate reasoning steps so the model generates a scratchpad before the final answer."];
  "kp_chain_rule_for_composed_functions" [label="Chain rule for composed\nfunctions", fillcolor="#ecfeff", tooltip="Gradients of composed scalar or vector functions are computed by multiplying derivatives or Jacobians along the computation path."];
  "kp_classical_cv_features" [label="Classical computer\nvision and hand-crafted\nfeatures", fillcolor="#f8fafc", tooltip="Pre-neural-network image pipelines that replaced raw pixels with human-designed descriptors such as color histograms or HOG before classification. The pre-deep-learning era emphasized parts, edges, grouping, matching, and handcrafted representations, with limited success on full recognition."];
  "kp_cnn_architecture_pattern_and_historical_role" [label="CNN architecture pattern\nand historical role", fillcolor="#fff7ed", tooltip="CNNs pair convolutional feature extraction with classifier heads and were the dominant vision architecture from LeNet through the AlexNet era before transformers became more common."];
  "kp_collective_communication_primitives" [label="Collective communication\nprimitives", fillcolor="#ecfeff", tooltip="All-reduce, reduce-scatter, all-gather, and reduce as the core synchronization operations behind DDP, ZeRO, and FSDP."];
  "kp_compositional_tree_semantics" [label="Compositional tree\nsemantics", fillcolor="#ecfeff", tooltip="Phrase meanings can be built compositionally over parse trees rather than only over flat token sequences."];
  "kp_computation_graphs_and_backprop" [label="Computational graphs and\nautomatic\ndifferentiation", fillcolor="#ecfeff", tooltip="General reverse-mode autodiff runs forward in topological order on a DAG and backward in reverse topological order, which is how modern frameworks implement backpropagation. A neural network can be understood as a directed acyclic graph of operations whose forward pass computes values and whose backward pass computes gradients."];
  "kp_concept_bottlenecks_for_controllable_rl_interventions" [label="Concept bottlenecks for\ncontrollable RL\ninterventions", fillcolor="#fff7ed", tooltip="Embedding explicit concepts inside agents enables targeted intervention studies that expose coordination structure and causal dependencies."];
  "kp_context_vector_as_a_weighted_sum" [label="Context vector as a\nweighted sum", fillcolor="#fff7ed", tooltip="The output of attention is a context vector formed by weighting source hidden states with attention weights and summing them."];
  "kp_contrastive_learning_and_infonce" [label="Contrastive learning and\nInfoNCE", fillcolor="#ecfeff", tooltip="A general SSL formulation that attracts positive pairs and repels negatives, optimized with the InfoNCE objective."];
  "kp_convolution_as_local_template_matching" [label="Convolution as local\ntemplate matching", fillcolor="#ecfeff", tooltip="A convolution layer preserves spatial structure by sliding small filters over local image patches and turning filter responses into activation maps."];
  "kp_convolution_hyperparameters_and_tensor_shapes" [label="Convolution\nhyperparameters and\ntensor shapes", fillcolor="#fff7ed", tooltip="Understanding filter count, kernel size, stride, padding, and the resulting input/output tensor shapes for convolution layers."];
  "kp_cross_attention" [label="Encoder-decoder cross-\nattention", fillcolor="#fff7ed", tooltip="At each decoding step, compute scores between the decoder state and encoder states, normalize them with softmax, form a context vector, and combine it with the decoder state to predict the next token. Cross-attention uses one set of query vectors to retrieve information from a separate set of data vectors, often from another modality or sequence."];
  "kp_cross_entropy_loss" [label="Cross-entropy loss and\nnegative log likelihood", fillcolor="#fff7ed", tooltip="Transform raw class scores into probabilities with softmax and learn by minimizing the negative log probability of the correct class, equivalent here to maximum likelihood and cross-entropy under one-hot labels. For one-hot targets, cross entropy reduces to the model's log probability of the correct class and is optimized as negative log likelihood."];
  "kp_ctc_for_monotonic_neural_to_phoneme_alignment" [label="CTC for monotonic\nneural-to-phoneme\nalignment", fillcolor="#fff7ed", tooltip="Connectionist Temporal Classification solves the mismatch between long neural sequences and shorter phoneme outputs when alignment is monotonic but unknown."];
  "kp_current_llm_benchmark_suites_and_task_coverage" [label="Current LLM benchmark\nsuites and task coverage", fillcolor="#ecfeff", tooltip="Modern LLM evaluation uses broad benchmark suites spanning math, knowledge, code, law, medicine, and other domains."];
  "kp_data_driven_learning_pipeline" [label="Data-driven supervised\nlearning pipeline", fillcolor="#ecfeff", tooltip="Pre-deep-learning progress came from shifting from hand-coded rules to learnable statistical models trained from data. The collect-train-predict paradigm: gather labeled data, fit a model, and evaluate predictions on unseen examples."];
  "kp_data_parallelism" [label="Data Parallelism", fillcolor="#ecfeff", tooltip="A baseline scaling method where each GPU processes a different minibatch shard, computes a local gradient, and synchronizes gradients across replicas."];
  "kp_decoder_only_pretraining" [label="Decoder-only pretraining", fillcolor="#f8fafc", tooltip="Training a causal decoder with next-token prediction, the foundation of GPT-style generative models."];
  "kp_deep_learning_resurgence" [label="Deep learning resurgence\nfrom data, compute, and\nscale", fillcolor="#fff7ed", tooltip="Why modern neural NLP depends on a set of training and modeling ideas that made deep networks workable after years of difficulty. Large-scale datasets, GPU computation, and neural architectures converged to unlock modern deep learning for vision."];
  "kp_degeneration_under_maximum_probability_decoding" [label="Degeneration under\nmaximum-probability\ndecoding", fillcolor="#f8fafc", tooltip="The failure mode where greedy or beam-style search produces repetitive, overconfident text in open-ended generation."];
  "kp_dependency_grammar" [label="Dependency grammar", fillcolor="#ecfeff", tooltip="A syntactic representation built from head-dependent relations, where each word is linked to the word it modifies or depends on."];
  "kp_detr_object_queries" [label="DETR object queries", fillcolor="#fff7ed", tooltip="DETR uses learned decoder queries to emit a set of object predictions, each containing a class, a box, or a no-object output."];
  "kp_discriminative_modeling_p_y_x" [label="Discriminative modeling\np(y|x)", fillcolor="#ecfeff", tooltip="A discriminative model predicts labels or outputs conditioned on an input and allocates probability mass across possible y values for each fixed x."];
  "kp_distilling_reasoning_traces_into_smaller_models" [label="Distilling reasoning\ntraces into smaller\nmodels", fillcolor="#fff7ed", tooltip="Use a strong teacher model to generate step-by-step explanations and fine-tune a smaller model on those explanations."];
  "kp_elbo_as_the_vae_training_objective" [label="ELBO as the VAE training\nobjective", fillcolor="#fff7ed", tooltip="The evidence lower bound keeps a reconstruction term and a KL-to-prior regularizer while discarding an intractable nonnegative KL term, yielding a tractable lower bound on log p(x)."];
  "kp_elementwise_multiplication_matrix_multiplication_and_dot_products" [label="Elementwise\nmultiplication, matrix\nmultiplication, and dot\nproducts", fillcolor="#fff7ed", tooltip="Distinguishing *, np.matmul/@, and np.dot behavior with attention to dimensional compatibility."];
  "kp_end_to_end_learning_for_images" [label="End-to-end learning for\nimages", fillcolor="#ecfeff", tooltip="Replacing hand-engineered feature stages with trainable image-processing operators that preserve spatial structure and are learned from data."];
  "kp_faithfulness_and_counterfactual_evaluation_of_reasoning" [label="Faithfulness and\ncounterfactual\nevaluation of reasoning", fillcolor="#fff7ed", tooltip="Reasoning quality should be tested by whether rationales causally affect answers and whether performance survives distribution shifts."];
  "kp_fixed_window_neural_language_models" [label="Fixed-window neural\nlanguage models", fillcolor="#fff7ed", tooltip="Neural next-word predictors that embed a limited context window and classify the next token with a softmax."];
  "kp_forward_pass_and_hand_built_2_layer_training_loop" [label="Forward pass and hand-\nbuilt 2-layer training\nloop", fillcolor="#fff7ed", tooltip="The minimal implementation pattern for a small neural network: define dimensions and weights, run the forward pass, compute loss, backpropagate, and update parameters."];
  "kp_fsdp" [label="Fully Sharded Data\nParallel (FSDP)", fillcolor="#f8fafc", tooltip="Stage-3 sharding scheme that partitions parameters, gradients, and optimizer state, then gathers per-layer weights on demand during forward and backward passes. A memory-saving variant of data parallelism that shards parameters, gradients, and optimizer state across GPUs and materializes weights on demand."];
  "kp_fsdp_sharding_policy_and_communication_overlap" [label="FSDP sharding policy and\ncommunication overlap", fillcolor="#fff7ed", tooltip="Implementation-level idea that FSDP efficiency depends on how layers are grouped into units and how communication is overlapped with computation."];
  "kp_generative_modeling_p_x_and_conditional_generation_p_x_y" [label="Generative modeling p(x)\nand conditional\ngeneration p(x|y)", fillcolor="#ecfeff", tooltip="Generative models allocate probability mass over possible data x, while conditional generative models do so within each conditioning signal y, enabling sampling and outlier rejection."];
  "kp_goal_state_action_reward_formulation" [label="Goal-state-action-reward\nformulation", fillcolor="#fff7ed", tooltip="Robot learning problems are structured around a task goal, current state, action choice, reward signal, and resulting next state."];
  "kp_gradient_based_learning_and_observed_minus_expected_updates" [label="Gradient-based learning\nand observed-minus-\nexpected updates", fillcolor="#fff7ed", tooltip="The word2vec parameters are optimized by differentiating the log-softmax objective, yielding gradients that compare observed context vectors against the model’s expected prediction."];
  "kp_gradient_checking" [label="Gradient checking", fillcolor="#fff7ed", tooltip="Central-difference finite-difference estimates provide a slow but useful way to verify that a manual backward implementation is correct. Finite-difference derivative approximations, exact calculus-based gradients, and implementation checks comparing the two."];
  "kp_gradient_descent_and_sgd" [label="Gradient descent and\nstochastic gradient\ndescent", fillcolor="#ecfeff", tooltip="Neural networks are trained by computing the gradient of an objective and updating parameters with stochastic gradient descent. Gradient-based optimization updates parameters by subtracting a scaled gradient, with the learning rate controlling step size."];
  "kp_greedy_recursive_constituency_parsing" [label="Greedy tree recursive\nparser", fillcolor="#fff7ed", tooltip="A recursive network can score and merge adjacent constituents greedily to build a binary parse and sentence representation."];
  "kp_human_centered_evaluation_and_metric_alignment" [label="Human-centered\nevaluation and metric\nalignment", fillcolor="#fff7ed", tooltip="Using human judgments as the gold standard and measuring whether automatic metrics agree with those judgments."];
  "kp_hybrid_sharded_data_parallelism_hsdp" [label="Hybrid Sharded Data\nParallelism (HSDP)", fillcolor="#fff7ed", tooltip="A 2D composition of FSDP within groups and ordinary data parallelism across groups, chosen to better match cluster communication hierarchy."];
  "kp_implicit_functions_for_geometry" [label="Implicit functions for\ngeometry", fillcolor="#ecfeff", tooltip="A representation in which surface points satisfy a condition like f(x,y,z)=0, enabling inside/outside reasoning and later neural field methods."];
  "kp_in_context_learning" [label="In-context learning", fillcolor="#fff7ed", tooltip="Solving a task from examples placed directly in the prompt, without updating model parameters. Task behavior induced by prompts and examples without parameter updates."];
  "kp_inter_agent_relationship_graphs_from_interventions" [label="Inter-agent relationship\ngraphs from\ninterventions", fillcolor="#fff7ed", tooltip="Graphs built from intervention outcomes can reveal hidden social or coordination structure that raw statistics miss."];
  "kp_key_query_value_self_attention_equations" [label="Key-query-value self-\nattention equations", fillcolor="#ecfeff", tooltip="Token embeddings are projected into queries, keys, and values; dot-product scores are softmax-normalized and used to compute weighted sums of value vectors."];
  "kp_kim_2014_sentence_classification_cnn" [label="Kim 2014 sentence-\nclassification CNN", fillcolor="#fff7ed", tooltip="A multi-filter text CNN with max pooling and softmax classification that became the canonical early NLP CNN baseline."];
  "kp_l1_l2_elastic_net_and_lambda" [label="L1, L2, elastic net, and\nlambda", fillcolor="#fff7ed", tooltip="Common regularization penalties and the lambda hyperparameter controlling penalty strength."];
  "kp_language_conditioned_agents" [label="Language-conditioned\nagents", fillcolor="#ecfeff", tooltip="An agent receives observations from an environment and a language instruction, then selects actions to complete the instructed task."];
  "kp_layer_wise_jacobians_for_activations_and_affine_maps" [label="Layer-wise Jacobians for\nactivations and affine\nmaps", fillcolor="#fff7ed", tooltip="Elementwise activations produce diagonal Jacobians, while affine maps such as Wx+b yield simple derivatives with respect to inputs and biases."];
  "kp_learned_forward_dynamics_for_model_based_planning" [label="Learned forward dynamics\nfor model-based planning", fillcolor="#fff7ed", tooltip="Instead of directly learning a policy, a robot can learn how actions change the world and use that model to optimize future action sequences."];
  "kp_limits_of_linear_classifiers" [label="Limits of linear\nclassifiers", fillcolor="#ecfeff", tooltip="Linear classifiers are weak for vision because they compress each class into a single template and can only create linear decision boundaries."];
  "kp_linear_classifier_as_a_parametric_score_function" [label="Linear classifier as a\nparametric score\nfunction", fillcolor="#ecfeff", tooltip="A learned affine map f(x,W)=Wx+b that converts a flattened image into class scores."];
  "kp_linear_classifier_scores_and_loss_functions" [label="Linear classifier scores\nand loss functions", fillcolor="#ecfeff", tooltip="Linear score functions, Softmax/cross-entropy, and dataset loss as an average of per-example losses."];
  "kp_local_parser_state_and_features" [label="Local parser state and\nfeatures", fillcolor="#ecfeff", tooltip="The representation of a parser decision state using the stack, buffer, nearby words, parts of speech, dependency labels, and other local structural cues."];
  "kp_local_upstream_and_downstream_gradients" [label="Local, upstream, and\ndownstream gradients", fillcolor="#fff7ed", tooltip="The node-level view of backprop where each node multiplies its local derivative by an incoming upstream gradient to produce gradients for earlier nodes."];
  "kp_lora_low_rank_adaptation" [label="LoRA low-rank adaptation", fillcolor="#fff7ed", tooltip="PEFT method that freezes base weights and learns a low-rank update for selected matrices, usually controlled by rank and scaling hyperparameters."];
  "kp_mask_r_cnn_for_instance_segmentation" [label="Mask R-CNN for instance\nsegmentation", fillcolor="#fff7ed", tooltip="Mask R-CNN augments a detection pipeline with a per-instance mask head so each detected object also receives a pixel mask."];
  "kp_masked_language_modeling" [label="Masked language modeling", fillcolor="#ecfeff", tooltip="Corrupting input text and training an encoder to reconstruct masked tokens using bidirectional context."];
  "kp_maximum_likelihood_estimation_for_density_models" [label="Maximum likelihood\nestimation for density\nmodels", fillcolor="#fff7ed", tooltip="Maximum likelihood fits probabilistic models by choosing parameters that maximize the probability or log-probability of the observed dataset under an assumed density family."];
  "kp_model_free_rl_successes_and_sim_to_real_limitations" [label="Model-free RL successes\nand sim-to-real\nlimitations", fillcolor="#ecfeff", tooltip="RL has produced dramatic wins in games and locomotion, yet still suffers from sample inefficiency, safety concerns, and limited robustness in many manipulation settings."];
  "kp_momentum_optimizer" [label="Momentum optimizer", fillcolor="#f8fafc", tooltip="Using velocity or a running average of gradients to smooth updates and keep moving in useful directions."];
  "kp_multi_head_self_attention" [label="Multi-head self-\nattention", fillcolor="#fff7ed", tooltip="Instead of one attention operation, transformers run several attention heads in parallel on lower-dimensional projections and then combine their outputs. Multi-head attention runs several independent attention heads in parallel and fuses them, increasing capacity while staying hardware-friendly."];
  "kp_multi_view_and_voxel_based_3d_deep_learning" [label="Multi-view and voxel-\nbased 3D deep learning", fillcolor="#fff7ed", tooltip="Early neural approaches that either render 3D shapes into multiple images for 2D CNNs or directly process voxel grids with 3D convolution."];
  "kp_n_gram_language_models" [label="N-gram language models", fillcolor="#f8fafc", tooltip="Count-based next-word models that use a short Markov context, smoothing, and backoff."];
  "kp_nearest_neighbor_classification" [label="Nearest neighbor\nclassification", fillcolor="#fff7ed", tooltip="A nonparametric classifier that stores all labeled examples and predicts by copying the label of the closest stored example."];
  "kp_neural_machine_translation_with_seq2seq_encoder_decoders" [label="Neural machine\ntranslation with\nsequence-to-sequence\nencoder-decoder models", fillcolor="#fff7ed", tooltip="Neural MT uses an end-to-end encoder-decoder network that directly models target generation conditioned on a source sentence."];
  "kp_neural_radiance_fields_and_differentiable_volume_rendering" [label="Neural radiance fields\nand differentiable\nvolume rendering", fillcolor="#fff7ed", tooltip="A neural field that predicts density and color from spatial position and view direction, trained through differentiable rendering from 2D images."];
  "kp_neural_spikes_as_the_basic_recorded_unit" [label="Neural spikes as the\nbasic recorded unit", fillcolor="#ecfeff", tooltip="Single-neuron recordings are framed in terms of action potentials and spike trains measured near neurons."];
  "kp_neural_transition_based_parser" [label="Neural transition-based\nparser", fillcolor="#fff7ed", tooltip="A transition parser that replaces sparse symbolic features with embeddings and a nonlinear neural classifier over parser actions."];
  "kp_object_detection_as_joint_classification_and_localization" [label="Object detection as\njoint classification and\nlocalization", fillcolor="#ecfeff", tooltip="Detection extends classification by predicting both an object category and bounding-box coordinates for each object."];
  "kp_observational_discovery_of_emergent_rl_behaviors" [label="Observational discovery\nof emergent RL behaviors", fillcolor="#ecfeff", tooltip="Latent-variable modeling of state-action traces can reveal recurring multi-agent behaviors without hand labeling every trajectory."];
  "kp_open_ended_generation" [label="Open-ended generation\nand evaluation", fillcolor="#fff7ed", tooltip="A way to categorize generation tasks by how many valid outputs they permit, with entropy used as a formal intuition for openness. Open-ended tasks have many valid answers and graded quality, so evaluation must move beyond exact labels."];
  "kp_paired_neural_text_data_collection" [label="Paired neural-text data\ncollection", fillcolor="#ecfeff", tooltip="Building a speech decoder requires supervised paired recordings of neural activity and target utterances collected under clinical constraints."];
  "kp_parametric_curves_and_surfaces" [label="Parametric curves and\nsurfaces", fillcolor="#ecfeff", tooltip="Representations that map a low-dimensional parameter domain such as t or (u,v) into points on a 2D or 3D shape."];
  "kp_peft" [label="Parameter-efficient\nfine-tuning", fillcolor="#ecfeff", tooltip="Fine-tuning approach that updates only a small subset of model parameters to reduce memory, storage, and sometimes overfitting risk. Adapting pretrained models by changing only a small number of parameters, such as prefixes, prompts, or low-rank weight updates."];
  "kp_pooling_and_translation_equivariance" [label="Pooling and translation\nequivariance", fillcolor="#fff7ed", tooltip="Pooling offers cheap spatial downsampling, and together with convolution exhibits translation equivariance, a property that matches how image content should be processed."];
  "kp_pooling_strategies_in_text_cnns" [label="Pooling strategies in\ntext CNNs", fillcolor="#ecfeff", tooltip="Max, average, local, and k-max pooling determine how local activations are summarized across a sentence."];
  "kp_population_decoding_from_noisy_motor_cortex_activity" [label="Population decoding from\nnoisy motor-cortex\nactivity", fillcolor="#fff7ed", tooltip="Movement intent is inferred by combining noisy single-neuron tuning information across multiple channels and learning decision boundaries."];
  "kp_practical_fine_tuning_decision_flowchart" [label="Practical fine-tuning\ndecision flowchart", fillcolor="#fff7ed", tooltip="Operational decision rule for choosing mixed precision, ZeRO stage 2 or 3, checkpointing, and LoRA based on hardware and memory constraints."];
  "kp_pytorch_training_loop" [label="PyTorch training loop", fillcolor="#fff7ed", tooltip="A standard PyTorch training loop combines forward computation, loss evaluation, backward gradient computation, and an optimizer step inside an epoch loop. Treating Hugging Face models as standard PyTorch modules inside a DataLoader-based training loop with optimizer and scheduler."];
  "kp_real_time_decoding_stack_with_grus_beam_search_and_language_models" [label="Real-time decoding stack\nwith GRUs, beam search,\nand language models", fillcolor="#fff7ed", tooltip="The final system couples a GRU acoustic-style decoder with beam search, lexicon constraints, fast n-gram language modeling, and transformer reranking."];
  "kp_receptive_fields_and_strided_downsampling" [label="Receptive fields and\nstrided downsampling", fillcolor="#f8fafc", tooltip="The receptive field measures how much of the original image can affect a later activation; stride and downsampling let that field grow faster with depth."];
  "kp_recursive_neural_tensor_networks" [label="Recursive neural tensor\nnetwork", fillcolor="#f8fafc", tooltip="An RNTN uses tensor-mediated interactions to model richer phrase composition than a standard recursive neural network."];
  "kp_region_proposals_and_the_r_cnn_progression" [label="Region proposals and the\nR-CNN progression", fillcolor="#ecfeff", tooltip="R-CNN, Fast R-CNN, and Faster R-CNN progressively reduce detection cost by sharing features and learning proposal generation."];
  "kp_regularization_and_generalization" [label="Regularization and\ngeneralization", fillcolor="#fff7ed", tooltip="The idea that more neurons increase expressive power and overfitting risk, so regularization—not shrinking the architecture by default—should control generalization. The view that very large networks can fit training data closely yet still generalize when regularization is chosen appropriately."];
  "kp_reparameterization_latent_sampling_and_disentangling_intuition" [label="Reparameterization,\nlatent sampling, and\ndisentangling intuition", fillcolor="#fff7ed", tooltip="VAE training samples latent variables through a differentiable reparameterization trick, and the resulting latent spaces often support sampling, interpolation, and axis-wise variation."];
  "kp_reshape_and_indexing" [label="Reshaping and indexing", fillcolor="#ecfeff", tooltip="PyTorch supports reshaping tensors, reducing dimensions with operations like sum and mean, and NumPy-style slicing and indexing for selecting substructures. How (3,), (1,3), and (3,1) differ, and how reshape changes array dimensions when element counts match."];
  "kp_rnn_basics" [label="Recurrent neural\nnetworks", fillcolor="#ecfeff", tooltip="Shared-parameter sequence models that update a hidden state over time to summarize prior context. Updating a hidden state from current input and previous hidden state at every time step."];
  "kp_rnn_lstm_applications_and_conditional_language_models" [label="RNN/LSTM applications\nand conditional language\nmodels", fillcolor="#ecfeff", tooltip="LSTMs can label sequences, encode whole sentences, and generate outputs conditioned on other inputs."];
  "kp_robot_learning_as_interactive_sequential_decision_making" [label="Robot learning as\ninteractive sequential\ndecision-making", fillcolor="#ecfeff", tooltip="Robot learning is distinguished from standard prediction problems because actions change the environment, generate new observations, and must be chosen over time to improve reward."];
  "kp_sampling_based_decoding_controls" [label="Sampling-based decoding\ncontrols", fillcolor="#fff7ed", tooltip="The family of stochastic decoding methods and hyperparameters such as top-k, top-p, epsilon, typical sampling, and temperature."];
  "kp_self_attention" [label="Self-attention", fillcolor="#ecfeff", tooltip="Self-attention applies attention within one set of vectors by projecting each input into a query, key, and value so every element can mix information from the whole set. Each token can gather information from every token in the sequence in a single parallel operation, rather than relying on stepwise recurrence."];
  "kp_seq2seq_attention_bottleneck" [label="Seq2seq bottleneck\nmotivation for attention", fillcolor="#ecfeff", tooltip="Encoder-decoder RNNs compress the input sequence into one context vector, which limits performance on longer sequences because all input-output communication must pass through that fixed-size representation. A single encoder hidden state is too narrow a bottleneck for long source sentences, motivating selective access to all encoder states during decoding."];
  "kp_sequence_classification_outputs_loss_and_predictions" [label="Sequence classification\noutputs, loss, and\npredictions", fillcolor="#fff7ed", tooltip="How to pass tokenized inputs through a classification model, read logits, obtain loss, and convert logits to predicted labels."];
  "kp_sgd_failure_modes" [label="SGD failure modes", fillcolor="#fff7ed", tooltip="Poor conditioning, overshoot, local minima, saddle points, and minibatch gradient noise."];
  "kp_simclr_and_moco_design_tradeoffs" [label="SimCLR and MoCo design\ntradeoffs", fillcolor="#fff7ed", tooltip="SimCLR uses in-batch negatives and a projection head, while MoCo uses a momentum-updated key encoder and a queue to reduce batch-size dependence."];
  "kp_softmax_probability_model_for_context_prediction" [label="Softmax probability\nmodel for context\nprediction", fillcolor="#ecfeff", tooltip="The conditional probability of an outside word given a center word is defined by exponentiating dot products and normalizing over the vocabulary."];
  "kp_syntactic_ambiguity_and_attachment" [label="Syntactic ambiguity and\nattachment", fillcolor="#fff7ed", tooltip="The fact that one surface word sequence can support multiple syntactic analyses, especially through PP attachment, coordination scope, and modifier scope."];
  "kp_synthetic_demonstrations_through_exploration_and_relabeling" [label="Synthetic demonstrations\nthrough exploration and\nrelabeling", fillcolor="#fff7ed", tooltip="Generate agent training data by exploring environments, labeling trajectories with inferred instructions, and iteratively refining both."];
  "kp_task_specific_model_classes_and_architecture_task_matching" [label="Task-specific model\nclasses and\narchitecture-task\nmatching", fillcolor="#fff7ed", tooltip="The idea that Hugging Face exposes different classes and heads for different tasks, and that valid task choices depend on whether a model is encoder-only, decoder-only, or encoder-decoder."];
  "kp_teacher_forcing_and_backpropagation_through_time" [label="Teacher forcing and\nbackpropagation through\ntime", fillcolor="#fff7ed", tooltip="The standard training setup for autoregressive RNNs, including per-token loss, repeated-weight gradients, and truncated BPTT."];
  "kp_tensor_shapes_and_broadcasting" [label="Tensor shapes and\nbroadcasting", fillcolor="#ecfeff", tooltip="Reasoning about tensor dimensions, shape compatibility, and broadcasting is necessary for elementwise operations, batching, and matrix multiplication. Core shape vocabulary for rectangular matrices, one-dimensional vectors, higher-dimensional tensors, and NumPy shape notation."];
  "kp_transformer_architecture" [label="Transformer block\narchitecture", fillcolor="#fff7ed", tooltip="The same core block yields a decoder-only model with masking, an encoder-only model without masking, and an encoder-decoder model with cross-attention. A transformer block combines self-attention, residual connections, normalization, and an MLP/FFN, and a full transformer is a stack of these blocks."];
  "kp_transformer_tokenization_outputs" [label="Transformer tokenization\noutputs", fillcolor="#ecfeff", tooltip="How raw text becomes input IDs, attention masks, and special-token-augmented sequences aligned with a model's vocabulary."];
  "kp_transformers_as_a_cross_domain_backbone" [label="Transformers as a cross-\ndomain backbone", fillcolor="#fff7ed", tooltip="The same transformer architecture supports next-token language models and vision transformers over image patches, and the lecture frames it as the dominant backbone for large AI models."];
  "kp_upstream_gradient_reuse_and_outer_product_parameter_gradients" [label="Upstream gradient reuse\nand outer-product\nparameter gradients", fillcolor="#fff7ed", tooltip="Shared upstream error signals should be reused across parameter derivatives, and weight gradients often combine the upstream signal with the local input in an outer-product form."];
  "kp_variational_autoencoder_latent_variable_model" [label="Variational autoencoder\nlatent-variable model", fillcolor="#ecfeff", tooltip="A VAE introduces latent variables z, a prior p(z), a decoder p_theta(x|z), and an encoder q_phi(z|x) that approximates the intractable posterior over latent codes."];
  "kp_vector_valued_gradients_and_jacobians" [label="Vector-valued gradients\nand Jacobians", fillcolor="#ecfeff", tooltip="The extension from scalar derivatives to vector-to-scalar and vector-to-vector settings, where Jacobians encode how each output component depends on each input component."];
  "kp_vectorization" [label="Vectorization", fillcolor="#fff7ed", tooltip="Implementing neural computation with vectors, matrices, and tensors instead of explicit loops. Using NumPy indexing and array operations instead of slow Python loops over large matrices."];
  "kp_weight_preference_effects_of_regularization" [label="Weight-preference\neffects of\nregularization", fillcolor="#fff7ed", tooltip="Regularizers encode preferences such as L2 spread-out weights and L1 sparsity."];
  "kp_word2vec_skipgram_objective" [label="Word2vec skip-gram\nobjective", fillcolor="#fff7ed", tooltip="Word2vec learns embeddings by maximizing the probability of observed context words around a center word across a corpus. The skip-gram model predicts context words from a center word using dot products between center and outside vectors."];
  "kp_word_vectors_and_embedding_spaces" [label="Word vectors and\nembedding spaces", fillcolor="#ecfeff", tooltip="Words are represented as dense vectors in a high-dimensional space where semantic relationships correspond to geometric structure such as large dot products and clustered neighborhoods."];
  "kp_yolo_one_stage_detection" [label="YOLO one-stage detection", fillcolor="#fff7ed", tooltip="YOLO predicts boxes and classes for all grid cells in a single pass and then filters them with confidence-based postprocessing."];
  "kp_zero_optimizer_and_gradient_sharding" [label="ZeRO optimizer and\ngradient sharding", fillcolor="#fff7ed", tooltip="ZeRO stages 1 and 2 reduce memory by sharding optimizer state and then gradients across workers while preserving synchronized updates."];
