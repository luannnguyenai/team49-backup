# =============================================================================
# .env.example — Copy to .env and fill in real values.
# NEVER commit .env to version control!
# =============================================================================

# ── LLM API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=your_gemini_api_key

# ── LLM Provider (google_genai | openai | anthropic) ──────────────────────────
# gpt-4o-mini: rẻ, hỗ trợ vision (VLM), tool calling, streaming
# Để dùng Gemini: MODEL_PROVIDER=google_genai, DEFAULT_MODEL=gemini-3-flash-preview, FAST_MODEL=gemini-2.0-flash
MODEL_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
FAST_MODEL=gpt-4o-mini

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_learning
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# Full async DSN (used by FastAPI / SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:change_me_strong_password@localhost:5432/ai_learning

# Cloud PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://app_user:your_password@your-db-host:5432/ai_learning
# If the provider gives a raw postgres URL, keep the same host/db/user/pass and use the asyncpg dialect above.

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379
# Full DSN (used by backend for session cache / rate-limiting)
REDIS_URL=redis://:change_me_redis_password@localhost:6379/0

# ── Security / JWT ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_min_32_chars_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_LOGIN_PER_MINUTE=5

# ── SQLAlchemy tuning ─────────────────────────────────────────────────────────
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Service ports (local dev) ─────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Next.js Frontend ──────────────────────────────────────────────────────────
# Dev: points to local FastAPI. Prod: your Railway/Cloud Run public URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development

# ── Production URLs (used in CI/CD deploy workflows) ─────────────────────────
# Set these in GitHub Actions → Settings → Secrets & Variables → Actions
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ── Vercel (frontend deploy) ──────────────────────────────────────────────────
# VERCEL_TOKEN=...          (GitHub Actions secret: VERCEL_TOKEN)
# VERCEL_ORG_ID=...         (GitHub Actions secret: VERCEL_ORG_ID)
# VERCEL_PROJECT_ID=...     (GitHub Actions secret: VERCEL_PROJECT_ID)

# ── Railway (backend deploy) ──────────────────────────────────────────────────
# RAILWAY_TOKEN=...         (GitHub Actions secret: RAILWAY_TOKEN)
# RAILWAY_SERVICE_ID=...    (GitHub Actions secret: RAILWAY_SERVICE_ID)

# ── Supabase (production DB) ──────────────────────────────────────────────────
# SUPABASE_DB_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres
#                           (GitHub Actions secret: SUPABASE_DB_URL)

# ── Knowledge Graph ───────────────────────────────────────────────────────────
KG_PHASE=0
ADMIN_TOKEN=your-admin-token-here

LOG_LEVEL=INFO

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log
