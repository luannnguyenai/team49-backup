# =============================================================================
# .env.example — copy to .env and fill in real values
# NEVER commit .env to version control!
# =============================================================================

# ── LLM API Keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=your_gemini_api_key

# Default model
DEFAULT_MODEL=gemini-3-flash-preview
LOG_LEVEL=INFO

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ai_learning
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:change_me_strong_password@localhost:5432/ai_learning

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379

# ── Security / JWT ─────────────────────────────────────────────────────────
SECRET_KEY=change_me_min_32_chars_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_LOGIN_PER_MINUTE=5

# ── SQLAlchemy tuning ──────────────────────────────────────────────────────
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DEBUG=false

# ── Service ports ──────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Next.js Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development

# ── AI Hook Logging ───────────────────────────────────────────────────────
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log
