{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "name": "log-prompt",
            "type": "command",
            "command": "AI_TOOL_NAME=claude python3 scripts/log_hook.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "name": "log-model",
            "type": "command",
            "command": "AI_TOOL_NAME=claude python3 scripts/log_hook.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "name": "log-session-end",
            "type": "command",
            "command": "AI_TOOL_NAME=claude python3 scripts/log_hook.py",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}