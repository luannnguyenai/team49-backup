# =============================================================================
# frontend/.env.example — Copy to .env.local and fill in values.
# NEVER commit .env.local to version control!
# =============================================================================

# ── API URL ────────────────────────────────────────────────────────────────────
# Dev: local FastAPI.  Prod (Vercel): your Railway backend URL.
# NEXT_PUBLIC_* vars are baked in at build time — rebuild required after change.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=development
